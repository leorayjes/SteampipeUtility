{
  "steampipe": {
    "plugins": [
      "aws"
    ]
  },
  "mods": [
    {
      "id": "aws_compliance",
      "namespace": "aws_compliance",
      "name": "AWS Compliance",
      "description": "CIS, PCI DSS, NIST, SOC 2, HIPAA and more",
      "mod": "github.com/turbot/steampipe-mod-aws-compliance",
      "benchmarks": [
        { "id": "all_controls",                          "name": "All Controls" },
        { "id": "foundational_security",                 "name": "AWS Foundational Security Best Practices" },
        { "id": "acsc_essential_eight",                  "name": "ACSC Essential Eight" },
        { "id": "audit_manager_control_tower",           "name": "Audit Manager Control Tower" },
        { "id": "cis_v400",                              "name": "CIS v4.0.0" },
        { "id": "cis_v300",                              "name": "CIS v3.0.0" },
        { "id": "cis_v200",                              "name": "CIS v2.0.0" },
        { "id": "cis_v150",                              "name": "CIS v1.5.0" },
        { "id": "cis_v140",                              "name": "CIS v1.4.0" },
        { "id": "cis_v130",                              "name": "CIS v1.3.0" },
        { "id": "cis_v120",                              "name": "CIS v1.2.0" },
        { "id": "cis_compute_service_v100",              "name": "CIS Compute Services v1.0.0" },
        { "id": "cis_controls_v8_ig1",                   "name": "CIS Controls v8 IG1" },
        { "id": "cisa_cyber_essentials",                 "name": "CISA Cyber Essentials" },
        { "id": "fedramp_low_rev_4",                     "name": "FedRAMP Low Rev 4" },
        { "id": "fedramp_moderate_rev_4",                "name": "FedRAMP Moderate Rev 4" },
        { "id": "ffiec",                                 "name": "FFIEC" },
        { "id": "gdpr",                                  "name": "GDPR" },
        { "id": "gxp_21_cfr_part_11",                   "name": "GxP 21 CFR Part 11" },
        { "id": "gxp_eu_annex_11",                      "name": "GxP EU Annex 11" },
        { "id": "hipaa_final_omnibus_security_rule_2013","name": "HIPAA Final Omnibus Security Rule 2013" },
        { "id": "hipaa_security_rule_2003",              "name": "HIPAA Security Rule 2003" },
        { "id": "nist_800_171_rev_2",                   "name": "NIST 800-171 Rev 2" },
        { "id": "nist_800_172",                         "name": "NIST 800-172" },
        { "id": "nist_800_53_rev_5",                    "name": "NIST 800-53 Rev 5" },
        { "id": "nist_800_53_rev_4",                    "name": "NIST 800-53 Rev 4" },
        { "id": "nist_csf_v2",                          "name": "NIST CSF v2.0" },
        { "id": "nist_csf",                             "name": "NIST CSF v1.1" },
        { "id": "nydfs_23",                             "name": "NYDFS 23 NYCRR 500" },
        { "id": "pci_dss_v40",                          "name": "PCI DSS v4.0" },
        { "id": "pci_dss_v321",                         "name": "PCI DSS v3.2.1" },
        { "id": "rbi_cyber_security",                   "name": "RBI Cyber Security Framework" },
        { "id": "rbi_itf_nbfc",                         "name": "RBI ITF NBFC" },
        { "id": "soc_2",                                "name": "SOC 2" }
      ],
      "supports_html": true,
      "supports_json": true,
      "report_script": "generate_compliance_report.py"
    },
    {
      "id": "aws_well_architected",
      "namespace": "aws_well_architected",
      "name": "AWS Well-Architected",
      "description": "AWS Well-Architected Framework checks across all pillars",
      "mod": "github.com/turbot/steampipe-mod-aws-well-architected",
      "benchmarks": [
        { "id": "well_architected_framework", "name": "Well-Architected Framework (All Pillars)" }
      ],
      "supports_html": true,
      "supports_json": true,
      "report_script": "generate_well_architected_report.py"
    },
    {
      "id": "aws_top10",
      "namespace": "aws_top_10",
      "name": "AWS Top 10 Security Checks",
      "description": "High-signal focused set of critical security findings",
      "mod": "github.com/turbot/steampipe-mod-aws-top-10",
      "benchmarks": [
        { "id": "account_security",                                  "name": "Account Security (All Top 10)" },
        { "id": "account_security_accurate_account_info",            "name": "1. Accurate account information" },
        { "id": "account_security_use_mfa",                          "name": "2. Use multi-factor authentication (MFA)" },
        { "id": "account_security_no_hardcoded_secrets",             "name": "3. No hard-coding secrets" },
        { "id": "account_security_limit_security_groups",            "name": "4. Limit security groups" },
        { "id": "account_security_intentional_data_policies",        "name": "5. Intentional data policies" },
        { "id": "account_security_centralize_cloudtrail_logs",       "name": "6. Centralize CloudTrail logs" },
        { "id": "account_security_validate_iam_roles",               "name": "7. Validate IAM roles" },
        { "id": "account_security_take_action_on_findings",          "name": "8. Take action on findings" },
        { "id": "account_security_rotate_keys",                      "name": "9. Rotate keys" },
        { "id": "account_security_dev_cycle",                        "name": "10. Be involved in the dev cycle" }
      ],
      "supports_html": true,
      "supports_json": true,
      "report_script": "generate_top10_report.py"
    },
    {
      "id": "aws_perimeter",
      "namespace": "aws_perimeter",
      "name": "AWS Perimeter",
      "description": "Public exposure and network perimeter checks",
      "mod": "github.com/turbot/steampipe-mod-aws-perimeter",
      "benchmarks": [
        { "id": "public_access",  "name": "Public Access" },
        { "id": "network_access", "name": "Network Access" },
        { "id": "shared_access",  "name": "Shared Access" }
      ],
      "supports_html": true,
      "supports_json": true,
      "report_script": "generate_perimeter_report.py"
    }
  ]
}
